{
  "name": "debt-collector-dashboard",
  "version": "1.0.0-alpha-3",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "postbuild": "rm -rf lib; mkdir lib; cp -r dist/assets lib/assets && cp dist/index.html lib",
    "lint": "eslint .",
    "test": "vitest",
    "preview": "vite preview",
    "release": "f() { npm version ${1:-patch} && pnpm build && pnpm publish --tag next && git push && git push --tags; }; f"
  },
  "files": [
    "lib"
  ],
  "devDependencies": {
    "autoprefixer": "^10.4.21",
    "minimatch": "^10.0.1",
    "postcss": "^8.5.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "recharts": "^2.15.3",
    "tailwindcss": "^4.1.7",
    "vitest": "^3.1.3",
    "@eslint/js": "^9.25.0",
    "@tailwindcss/vite": "^4.1.7",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "eslint": "^9.25.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^16.0.0",
    "jsdom": "^26.1.0",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.30.1",
    "vite": "^6.3.5"
  }
}
